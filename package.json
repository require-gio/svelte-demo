{
	"name": "svelte-demo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "BODY_SIZE_LIMIT=Infinity HOST=0.0.0.0 PORT=$DATABRICKS_APP_PORT node build/index.js",
		"prepare": "svelte-kit sync || echo ''",
