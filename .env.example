# Databricks Configuration
# For local development only – in Databricks Apps, these are auto-injected.
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi...


# Kommaseparierte Liste aller Tabellen für den Daten-Explorer (vollqualifiziert)
# In Databricks Apps, injected via secret resource
DATABRICKS_TABLES=catalog.schema.versicherungen,catalog.schema.schaeden

# SQL Warehouse ID for the Data Explorer (query execution)
# In Databricks Apps, injected via sql-warehouse resource
DATABRICKS_WAREHOUSE_ID=abc123def456

# Genie Space ID (aus der Genie Space URL)
# In Databricks Apps, injected via resource
# z.B. https://example.databricks.com/genie/rooms/12ab345cd6789000ef6a2fb844ba2d31
GENIE_SPACE_ID=12ab345cd6789000ef6a2fb844ba2d31
